---
import MainLayout from "../layouts/MainLayout.astro";

//Server Only:
const title = "Home Page";
const name = "Andres Eugenio Guerrero Cordero";
---

<MainLayout title={title}>
  <h1>{name}</h1>

  <p>Momento actual: {new Date().toLocaleTimeString()}</p>
  <p id="current-time">Momento actual real:</p>

  <script>
    //Client Only:
    const currentTimeParagraph = document.querySelector(
      "#current-time",
    ) as HTMLParagraphElement;

    const currentTime: string = new Date().toLocaleTimeString();
    currentTimeParagraph.innerText = `Momento actual real: ${currentTime}`;
  </script>
</MainLayout>
