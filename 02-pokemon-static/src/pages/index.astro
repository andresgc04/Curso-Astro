---
import type { PokemonListResponse } from "../interfaces/pokemon-list.response";
import MainLayout from "../layouts/MainLayout.astro";
import PokemonCard from "../components/pokemons/PokemonCard.astro";

const response = await fetch("https://pokeapi.co/api/v2/pokemon");
const data = (await response.json()) as PokemonListResponse;

console.log("🚀 ~ data:", data);

const title = "Pokémon Static | Home";
---

<MainLayout title={title}>
  <h1 class="text-3xl">Listado de Pokémons</h1>
  <hr />

  <section
    aria-label="Listado de Pokémons"
    class="grid grid-cols-1 sm:grid-cols-3 md:grid-cols-3 gap-4 mt-5"
  >
    <!-- {data.results.map((pokemon) => <li>{pokemon.name}</li>)} -->
    {data.results.map(({ name, url }) => <PokemonCard name={name} url={url} />)}
  </section>
</MainLayout>
